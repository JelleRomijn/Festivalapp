# Altijd vers: service worker en Workbox runtime
<FilesMatch "^(sw|workbox-.+)\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Altijd vers: HTML pagina's
<FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Eeuwig cachen: gehashde Next.js chunks (filename bevat hash, veranderen nooit)
<FilesMatch "-.{8,}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
